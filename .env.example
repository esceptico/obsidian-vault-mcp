# obsidian-mcp configuration. Copy to `.env` and edit values for your machine.
# `.env` is gitignored. The server reads it via pydantic-settings.

# ---- Required ---------------------------------------------------------------

# Absolute path to the Obsidian vault directory.
OBSIDIAN_MCP_VAULT_ROOT=/Users/you/Documents/MyVault


# ---- Auth (strongly recommended; required for non-loopback hosts) ----------

# Static bearer token clients must send as `Authorization: Bearer <token>`.
# Generate something opaque: `python -c "import secrets; print(secrets.token_urlsafe(32))"`
OBSIDIAN_MCP_AUTH_TOKEN=change-me

# Public URL advertised in OAuth metadata. Set this if you put the server
# behind a reverse proxy / tunnel; otherwise it defaults to http://HOST:PORT
# and clients that validate issuer URLs will fail.
# OBSIDIAN_MCP_PUBLIC_URL=https://obsidian.example.com


# ---- Bind address ----------------------------------------------------------

OBSIDIAN_MCP_HOST=127.0.0.1
OBSIDIAN_MCP_PORT=8000


# ---- Vault layout (defaults match Obsidian conventions) --------------------

# OBSIDIAN_MCP_TRASH_PATH=.trash
# OBSIDIAN_MCP_DEFAULT_NOTE_FOLDER=Inbox
# OBSIDIAN_MCP_DAILY_NOTES_PATH=Daily
# OBSIDIAN_MCP_ATTACHMENTS_PATH=Assets
# OBSIDIAN_MCP_TEMPLATES_PATH=Templates


# ---- Embeddings (optional; enables vector + hybrid search) -----------------

# OBSIDIAN_MCP_OPENAI_API_KEY=sk-...
# OBSIDIAN_MCP_EMBEDDING_MODEL=text-embedding-3-small
# OBSIDIAN_MCP_EMBEDDING_DIMENSIONS=1536
# OBSIDIAN_MCP_EMBEDDING_BATCH_SIZE=64
