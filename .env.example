# obsidian-vault-mcp configuration. Copy to `.env` and edit values for your machine.
# `.env` is gitignored. The server reads it via pydantic-settings.

# ---- Required ---------------------------------------------------------------

# Absolute path to the Obsidian vault directory.
OBSIDIAN_VAULT_MCP_VAULT_ROOT=/Users/you/Documents/MyVault


# ---- Auth (strongly recommended; required for non-loopback hosts) ----------

# Static bearer token clients must send as `Authorization: Bearer <token>`.
# Generate something opaque: `python -c "import secrets; print(secrets.token_urlsafe(32))"`
OBSIDIAN_VAULT_MCP_AUTH_TOKEN=change-me


# ---- Bind address ----------------------------------------------------------

OBSIDIAN_VAULT_MCP_HOST=127.0.0.1
OBSIDIAN_VAULT_MCP_PORT=8000


# ---- Vault layout (defaults match Obsidian conventions) --------------------

# OBSIDIAN_VAULT_MCP_TRASH_PATH=.trash
# OBSIDIAN_VAULT_MCP_DEFAULT_NOTE_FOLDER=Inbox
# OBSIDIAN_VAULT_MCP_DAILY_NOTES_PATH=Daily
# OBSIDIAN_VAULT_MCP_ATTACHMENTS_PATH=Assets
# OBSIDIAN_VAULT_MCP_TEMPLATES_PATH=Templates


# ---- Embeddings (optional; enables vector + hybrid search) -----------------

# OBSIDIAN_VAULT_MCP_OPENAI_API_KEY=sk-...
# OBSIDIAN_VAULT_MCP_OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OBSIDIAN_VAULT_MCP_EMBEDDING_MODEL=text-embedding-3-small
# OBSIDIAN_VAULT_MCP_EMBEDDING_DIMENSIONS=1536
# OBSIDIAN_VAULT_MCP_EMBEDDING_BATCH_SIZE=64
